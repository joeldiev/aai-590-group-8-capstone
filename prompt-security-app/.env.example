CLASSIFIER_THRESHOLD_PATH=models/classifier/best/classification_threshold.json

SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
MAX_PROMPT_LENGTH=20000

FORCE_CPU=false
