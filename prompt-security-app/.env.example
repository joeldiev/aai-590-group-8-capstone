APP_NAME=dae-prompt-anomaly-api
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false

HOST=0.0.0.0
PORT=8000

PROJECT_ROOT=..
MODEL_DIR=models
FEATURE_ARTIFACT_DIR=models/feature_engineering/feature_pipeline
ANOMALY_MODEL_DIR=models/anomaly_detection/denoising_autoencoder/best
CLASSIFIER_MODEL_DIR=models/classifier/best

FEATURE_PIPELINE_BUNDLE_PATH=models/feature_engineering/feature_pipeline/feature_pipeline.joblib
FEATURE_FILL_VALUES_PATH=models/feature_engineering/feature_pipeline/fill_values.joblib
FEATURE_SCALER_PATH=models/anomaly_detection/denoising_autoencoder/best/scaler.joblib
FEATURE_SELECTED_COLUMNS_PATH=models/anomaly_detection/denoising_autoencoder/best/feature_columns.joblib
FEATURE_VARIANCE_SELECTOR_PATH=models/feature_engineering/feature_pipeline/variance_selector.joblib
FEATURE_CORRELATION_DROP_COLUMNS_PATH=models/feature_engineering/feature_pipeline/correlation_drop_columns.joblib
FEATURE_METADATA_PATH=models/feature_engineering/feature_pipeline/feature_pipeline_metadata.json

DAE_STATE_DICT_PATH=models/anomaly_detection/denoising_autoencoder/best/autoencoder_model.pt
DAE_METADATA_PATH=models/anomaly_detection/denoising_autoencoder/best/metadata.json
THRESHOLD_PATH=models/anomaly_detection/denoising_autoencoder/best/thresholds.json
CLASSIFIER_INFERENCE_CONFIG_PATH=models/classifier/best/inference_config.json
